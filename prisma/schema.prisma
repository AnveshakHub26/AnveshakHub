  status      String   @default("SUBMITTED") // SUBMITTED, APPROVED, DISBURSED, REJECTED
  receiptUrl  String?
  createdAt   DateTime @default(now())

  @@index([expertId])
}

// ─────────────────────────────────────────────────────────────────
// EXP-009 - EXP-012 — ANALYTICS, NOTIFICATIONS, SETTINGS & SUPPORT
// ─────────────────────────────────────────────────────────────────

model ExpertSetting {
  id              String   @id @default(uuid())
  expertId        String   @unique
  emailAlerts     Boolean  @default(true)
  smsAlerts       Boolean  @default(false)
  mfaEnabled      Boolean  @default(false)
  privacyMode     Boolean  @default(false)
  theme           String   @default("LIGHT")
  defaultCurrency String   @default("INR")
  updatedAt       DateTime @updatedAt

  @@index([expertId])
}

model ExpertSupportTicket {
  id           String   @id @default(uuid())
  expertId     String
  ticketNumber String   @unique
  subject      String
  category     String   @default("TECHNICAL") // TECHNICAL, REIMBURSEMENT, VERIFICATION, FEATURE_REQUEST
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status       String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  messages     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expertId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────
// STU-003 & STU-004 — STUDENT OPPORTUNITIES & PROJECT MANAGEMENT
// ─────────────────────────────────────────────────────────────────

model StudentApplication {
  id            String                 @id @default(uuid())
  studentId     String
  student       StudentProfile         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   MarketplaceOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  coverLetter   String?
  resumeUrl     String?
  status        String                 @default("APPLIED") // APPLIED, SHORTLISTED, SELECTED, REJECTED
  createdAt     DateTime               @default(now())

  @@index([studentId])
  @@index([opportunityId])
}

model StudentSavedOpportunity {
  id            String   @id @default(uuid())
  studentId     String
  opportunityId String
  createdAt     DateTime @default(now())

  @@index([studentId])
  @@index([opportunityId])
}

// ─────────────────────────────────────────────────────────────────
// STU-005 & STU-006 — LEARNING, MENTORSHIP & MEETINGS
// ─────────────────────────────────────────────────────────────────

model LearningResource {
  id          String   @id @default(uuid())
  title       String
  category    String   @default("EMBEDDED_SYSTEMS") // EMBEDDED_SYSTEMS, SIMULINK, ROS2, GENERAL
  url         String
  description String
  createdAt   DateTime @default(now())
}

model StudentMeeting {
  id          String    @id @default(uuid())
  studentId   String
  title       String
  orgName     String
  startTime   DateTime
  endTime     DateTime
  platform    String    @default("GOOGLE_MEET") // GOOGLE_MEET, MS_TEAMS, ZOOM
  videoLink   String
  status      String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  agenda      String?
  momNotes    String?
  actionItems Json?
  createdAt   DateTime  @default(now())

  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────
// STU-007 & STU-008 — DOCUMENTS, CERTIFICATES, PROGRESS & ACHIEVEMENTS
// ─────────────────────────────────────────────────────────────────

model StudentCertificate {
  id                 String   @id @default(uuid())
  studentId          String
  title              String
  issuer             String
  credentialId       String?
  issueDate          DateTime?
  verificationStatus String   @default("VERIFIED") // VERIFIED, PENDING, EXPIRED
  certificateUrl     String?
  createdAt          DateTime @default(now())

  @@index([studentId])
}

model StudentAchievement {
  id          String    @id @default(uuid())
  studentId   String
  title       String
  issuer      String
  category    String    @default("HACKATHON") // HACKATHON, FELLOWSHIP, HONORS, ACADEMIC
  awardDate   DateTime?
  description String?
  createdAt   DateTime  @default(now())

  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────
// STU-009 - STU-012 — ANALYTICS, NOTIFICATIONS, SETTINGS & SUPPORT
// ─────────────────────────────────────────────────────────────────

model StudentSetting {
  id              String   @id @default(uuid())
  studentId       String   @unique
  emailAlerts     Boolean  @default(true)
  smsAlerts       Boolean  @default(false)
  mfaEnabled      Boolean  @default(false)
  privacyMode     Boolean  @default(false)
  theme           String   @default("LIGHT")
  defaultCurrency String   @default("INR")
  updatedAt       DateTime @updatedAt

  @@index([studentId])
}

model StudentSupportTicket {
  id           String   @id @default(uuid())
  studentId    String
  ticketNumber String   @unique
  subject      String
  category     String   @default("TECHNICAL") // TECHNICAL, REIMBURSEMENT, VERIFICATION, FEATURE_REQUEST
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status       String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  messages     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}








