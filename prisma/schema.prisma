datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// ENUMS — AUTH / CORE
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  CRM_SPECIALIST
  COMPLIANCE_OFFICER
  VERIFICATION_OFFICER
  INDUSTRY_MANAGER
  STAKEHOLDER
}

enum OrgStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ON_HOLD
}

enum LeadStage {
  LEAD
  QUALIFIED
  MEETING_SCHEDULED
  PROPOSAL_SHARED
  NEGOTIATION
  APPROVED
  PROJECT_INITIATED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum ServiceStatus {
  ONLINE
  WARNING
  OFFLINE
}

// ─────────────────────────────────────────────
// ENUMS — ADM-003 VERIFICATION
// ─────────────────────────────────────────────

enum VerificationType {
  INDUSTRY
  EXPERT
  STUDENT
  PARTNER
  VENDOR
  GOVERNMENT
  CONTRIBUTOR
}

enum VerificationStage {
  SUBMITTED
  INITIAL_REVIEW
  DOCUMENT_VERIFICATION
  BUSINESS_VALIDATION
  MEETING_SCHEDULED
  COMPLIANCE_REVIEW
  APPROVAL_COMMITTEE
  APPROVED
  REJECTED
  ON_HOLD
}

enum VerificationPriority {
  STANDARD
  HIGH
  URGENT
  CRITICAL
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  REUPLOAD_REQUESTED
}

enum DocumentCategory {
  GST
  PAN
  CIN
  LLP
  MSME
  STARTUP_INDIA
  GOVERNMENT_CERT
  UNIVERSITY_PROOF
  EMPLOYMENT_PROOF
  NOC
  NDA
  MOU
  IDENTITY_PROOF
  ADDRESS_PROOF
  OTHER
}

enum MeetingPlatform {
  GOOGLE_MEET
  MICROSOFT_TEAMS
  ZOOM
  PHYSICAL
}

enum ReviewRecommendation {
  APPROVE
  REJECT
  HOLD
  ESCALATE
  REQUEST_MORE_INFO
}

// ─────────────────────────────────────────────
// ENUMS — ADM-004 INDUSTRY
// ─────────────────────────────────────────────

enum IndustryLifecycle {
  REGISTERED
  VERIFIED
  MEETING_COMPLETED
  OPPORTUNITY_CREATED
  EXPERTS_ASSIGNED
  PROJECT_STARTED
  PROJECT_COMPLETED
  LONG_TERM_PARTNER
}

enum ContactRole {
  PRIMARY
  SECONDARY
  FINANCE
  HR
  TECHNICAL
  LEGAL
}

enum VaultDocType {
  NDA
  MOU
  CONTRACT
  INVOICE
  REPORT
  IP_AGREEMENT
  PROJECT_DOC
  OTHER
}

// ─────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String
  role                 Role                  @default(STAKEHOLDER)
  department           String?
  avatarUrl            String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditLogs            AuditLog[]
  sessions             Session[]
  verificationActions  VerificationAction[]
  assignedRequests     VerificationRequest[] @relation("AssignedOfficer")
  reviewNotes          ReviewNote[]
  expertProfile        ExpertProfile?
  studentProfile       StudentProfile?
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// ORGANIZATION (existing, extended)
// ─────────────────────────────────────────────

model Organization {
  id                   String               @id @default(uuid())
  orgName              String
  orgType              String
  email                String               @unique
  phone                String
  website              String?
  industryDomain       String
  businessCategory     String
  description          String?
  state                String
  district             String
  city                 String
  pin                  String
  addressLine          String
  verificationStatus   OrgStatus            @default(PENDING)
  priority             String               @default("STANDARD")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  leads                Lead[]
  documents            Document[]
  verificationRequest  VerificationRequest?
  industryProfile      IndustryProfile?
  branches             Branch[]
  departments          Department[]
  representatives      Representative[]
  orgUsers             OrganizationUser[]
}

// ─────────────────────────────────────────────
// CRM MODELS (existing)
// ─────────────────────────────────────────────

model Lead {
  id            String       @id @default(uuid())
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stage         LeadStage    @default(LEAD)
  healthScore   Int          @default(100)
  estRevenue    Decimal      @default(0.0) @db.Decimal(12, 2)
  assignedTo    String?
  lastContacted DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  meetings      Meeting[]
  tasks         Task[]
}

model Document {
  id           String       @id @default(uuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  type         String
  url          String
  verified     Boolean      @default(false)
  createdAt    DateTime     @default(now())
}

model Meeting {
  id           String          @id @default(uuid())
  leadId       String?
  lead         Lead?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  verReqId     String?
  verificationRequest VerificationRequest? @relation(fields: [verReqId], references: [id])
  projectId    String?
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  industryId   String?
  industry     IndustryProfile? @relation(fields: [industryId], references: [id], onDelete: SetNull)
  title        String
  agenda       String?
  momNotes     String?
  participants String[]
  startTime    DateTime
  endTime      DateTime
  platform     MeetingPlatform @default(GOOGLE_MEET)
  videoLink    String?
  recordingUrl String?
  outcomes     String?
  notes        String?
  isRecurring  Boolean         @default(false)
  recurrenceRule String?
  status       String          @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  actionItemsList MeetingActionItem[]
  feedbacks       MeetingFeedback[]
  documents       MeetingDocument[]

  @@index([industryId])
  @@index([status])
  @@index([startTime])
}

model Task {
  id          String       @id @default(uuid())
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SystemHealth {
  id          String        @id @default(uuid())
  service     String        @unique
  status      ServiceStatus @default(ONLINE)
  latencyMs   Int           @default(0)
  lastChecked DateTime      @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  browser    String?
  details    String?
  timestamp  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  industryId String?
  title      String
  message    String
  category   String   @default("INFO")
  read       Boolean  @default(false)
  link       String?
  channel    String   @default("IN_APP") // IN_APP, EMAIL, ANNOUNCEMENT
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([industryId])
}

// ─────────────────────────────────────────────
// ADM-003 — VERIFICATION & APPROVAL CENTER
// ─────────────────────────────────────────────

model VerificationRequest {
  id                 String               @id @default(uuid())
  orgId              String               @unique
  organization       Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type               VerificationType     @default(INDUSTRY)
  stage              VerificationStage    @default(SUBMITTED)
  priority           VerificationPriority @default(STANDARD)
  assignedOfficerId  String?
  assignedOfficer    User?                @relation("AssignedOfficer", fields: [assignedOfficerId], references: [id])
  riskScore          Int                  @default(50)
  complianceStatus   Boolean              @default(false)
  fraudFlag          Boolean              @default(false)
  duplicateFlag      Boolean              @default(false)
  rejectionReason    String?
  rejectionComments  String?
  requiredCorrections String?
  resubmissionDeadline DateTime?
  submittedAt        DateTime             @default(now())
  reviewedAt         DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  documents          VerificationDocument[]
  actions            VerificationAction[]
  reviewNotes        ReviewNote[]
  meetings           Meeting[]

  @@index([stage])
  @@index([type])
  @@index([priority])
  @@index([assignedOfficerId])
}

model VerificationDocument {
  id              String               @id @default(uuid())
  verReqId        String
  verificationRequest VerificationRequest @relation(fields: [verReqId], references: [id], onDelete: Cascade)
  name            String
  category        DocumentCategory     @default(OTHER)
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  status          DocumentStatus       @default(PENDING)
  reviewerComment String?
  reviewedBy      String?
  reviewedAt      DateTime?
  version         Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([verReqId])
  @@index([status])
}

model VerificationAction {
  id          String            @id @default(uuid())
  verReqId    String
  verificationRequest VerificationRequest @relation(fields: [verReqId], references: [id], onDelete: Cascade)
  adminId     String?
  admin       User?             @relation(fields: [adminId], references: [id])
  action      String
  fromStage   VerificationStage?
  toStage     VerificationStage?
  notes       String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime          @default(now())

  @@index([verReqId])
  @@index([adminId])
}

model ReviewNote {
  id             String                @id @default(uuid())
  verReqId       String
  verificationRequest VerificationRequest @relation(fields: [verReqId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?                 @relation(fields: [authorId], references: [id])
  content        String
  recommendation ReviewRecommendation?
  isInternal     Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([verReqId])
}

// ─────────────────────────────────────────────
// ADM-004 — INDUSTRY MANAGEMENT
// ─────────────────────────────────────────────

model IndustryProfile {
  id              String           @id @default(uuid())
  orgId           String           @unique
  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lifecycle       IndustryLifecycle @default(REGISTERED)
  engagementScore Int              @default(0)
  collaborationScore Int           @default(0)
  avgResponseTime Int              @default(0)
  totalProjects   Int              @default(0)
  activeProjects  Int              @default(0)
  totalRevenue    Decimal          @default(0.0) @db.Decimal(14, 2)
  expertsAssigned Int              @default(0)
  studentsAssigned Int             @default(0)
  notes           String?
  tags            String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  contacts        IndustryContact[]
  timeline        IndustryTimeline[]
  vaultDocuments  DocumentVault[]
  students        StudentProfile[]
  projects        Project[]
  applications    InternshipApplication[]
  opportunities   MarketplaceOpportunity[]
  problemStatements ProblemStatement[]
  meetings          Meeting[]
  expertDiscussions ExpertCollaborationDiscussion[]

  @@index([lifecycle])
  @@index([engagementScore])
}


model IndustryContact {
  id              String          @id @default(uuid())
  industryId      String
  industry        IndustryProfile @relation(fields: [industryId], references: [id], onDelete: Cascade)
  role            ContactRole     @default(PRIMARY)
  name            String
  email           String
  phone           String?
  designation     String?
  department      String?
  linkedIn        String?
  isPrimary       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([industryId])
  @@index([role])
}

model IndustryTimeline {
  id          String          @id @default(uuid())
  industryId  String
  industry    IndustryProfile @relation(fields: [industryId], references: [id], onDelete: Cascade)
  event       String
  description String?
  category    String          @default("GENERAL")
  performedBy String?
  createdAt   DateTime        @default(now())

  @@index([industryId])
}

model DocumentVault {
  id                String          @id @default(uuid())
  industryId        String
  industry          IndustryProfile @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name              String
  docType           VaultDocType    @default(OTHER)
  fileUrl           String
  fileSize          Int?
  mimeType          String?
  version           Int             @default(1)
  previousVersionId String?
  uploadedBy        String?
  description       String?
  expiresAt         DateTime?
  accessLevel       String          @default("RESTRICTED") // PUBLIC, INTERNAL, RESTRICTED, CONFIDENTIAL
  approvalStatus    String          @default("APPROVED") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED
  tags              String[]
  downloadCount     Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([industryId])
  @@index([docType])
  @@index([accessLevel])
}

// ─────────────────────────────────────────────
// ENUMS & MODELS FOR EXPERT & STUDENT MANAGEMENT
// ─────────────────────────────────────────────

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  ON_LEAVE
}

enum ExpertDocType {
  NOC
  NDA
  MOU
  CERTIFICATE
  OTHER
}

enum StudentDocType {
  RESUME
  CERTIFICATE
  MARKS_CARD
  OTHER
}

model ExpertProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation       String
  institution       String
  department        String?
  yearsOfExp        Int
  bio               String?
  rating            Float              @default(5.0)
  availability      AvailabilityStatus @default(AVAILABLE)
  linkedinUrl       String?
  googleScholar     String?
  orcid             String?
  skills            String[]
  domains           String[]
  certifications        Json?
  employmentHistory     Json?
  hourlyRate            Decimal?           @default(0.0) @db.Decimal(10, 2)
  preferredHoursPerWeek Int?               @default(10)
  patents               Json?
  publications_list     Json?
  verificationStatus    String             @default("VERIFIED") // PENDING, UNDER_REVIEW, VERIFIED, REJECTED
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  
  projects          Project[]
  students          StudentProfile[]
  documents         ExpertDocument[]
  resourceRequests  ResourceRequest[]
  timeline          ExpertTimeline[]
  marketplaceApplications MarketplaceApplication[]
  marketplaceInvitations  MarketplaceInvitation[]
  marketplaceReviews      MarketplaceReview[]
  expertDiscussions ExpertCollaborationDiscussion[]
}


model StudentProfile {
  id                 String               @id @default(uuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  usn                String?
  institution        String
  degree             String
  branch             String
  semester           Int
  cgpa               Float
  bio                String?
  skills             String[]
  resumeUrl          String?
  portfolioUrl       String?
  linkedinUrl        String?
  githubUrl          String?
  certifications     Json?
  achievements       Json?
  careerInterests    String[]
  projectsList       Json?
  verificationStatus OrgStatus            @default(PENDING)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  
  expertId           String?
  expert             ExpertProfile?       @relation(fields: [expertId], references: [id], onDelete: SetNull)
  industryId         String?
  industry           IndustryProfile?     @relation(fields: [industryId], references: [id], onDelete: SetNull)
  
  projects           Project[]
  documents          StudentDocument[]
  timeline           StudentTimeline[]
  applications       InternshipApplication[]
  studentApplications StudentApplication[]
  attendance         StudentAttendance[]
  milestones         StudentMilestone[]
}

model Project {
  id               String                 @id @default(uuid())
  name             String
  description      String?
  lifecycle        String                 @default("DRAFT") // DRAFT, SUBMITTED, UNDER_REVIEW, APPROVED, PLANNING, IN_PROGRESS, TESTING, CLIENT_REVIEW, COMPLETED, ARCHIVED
  budget           Decimal                @default(0.0) @db.Decimal(12, 2)
  startDate        DateTime?
  endDate          DateTime?
  problemStatement String?
  scopeDefinition  String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  
  industryId       String?
  industry         IndustryProfile?       @relation(fields: [industryId], references: [id], onDelete: SetNull)
  experts          ExpertProfile[]
  students         StudentProfile[]
  
  milestones       ProjectMilestone[]
  sprints          ProjectSprint[]
  tasks            ProjectTask[]
  documents        ProjectDocument[]
  risks            ProjectRisk[]
  issues           ProjectIssue[]
  changeRequests   ProjectChangeRequest[]
  comments         ProjectComment[]
  activities       ProjectActivity[]
  meetings         Meeting[]
  invoices         Invoice[]
  
  problemStatementRefId String?
  problemStatementRef   ProblemStatement?    @relation(fields: [problemStatementRefId], references: [id])
}

model ExpertDocument {
  id              String         @id @default(uuid())
  expertId        String
  expert          ExpertProfile  @relation(fields: [expertId], references: [id], onDelete: Cascade)
  name            String
  docType         ExpertDocType  @default(OTHER)
  fileUrl         String
  status          DocumentStatus @default(PENDING)
  reviewerComment String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([expertId])
}

model StudentDocument {
  id              String         @id @default(uuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name            String
  docType         StudentDocType @default(OTHER)
  fileUrl         String
  status          DocumentStatus @default(PENDING)
  reviewerComment String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([studentId])
}

model InternshipApplication {
  id           String          @id @default(uuid())
  studentId    String
  student      StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  industryId   String
  industry     IndustryProfile @relation(fields: [industryId], references: [id], onDelete: Cascade)
  status       String          @default("PENDING") // PENDING, SHORTLISTED, OFFERED, PLACED, REJECTED
  coverLetter  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([studentId])
  @@index([industryId])
}

model StudentAttendance {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String         @default("PRESENT") // PRESENT, ABSENT, LEAVE
  notes     String?
  createdAt DateTime       @default(now())

  @@index([studentId])
}

model StudentMilestone {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String         @default("PENDING") // PENDING, COMPLETED, MISSED
  rating      Int?
  dueDate     DateTime?
  createdAt   DateTime       @default(now())

  @@index([studentId])
}

model ResourceRequest {
  id          String        @id @default(uuid())
  expertId    String
  expert      ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  title       String
  description String?
  quantity    Int           @default(1)
  status      String        @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime      @default(now())

  @@index([expertId])
}

model ExpertTimeline {
  id          String        @id @default(uuid())
  expertId    String
  expert      ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  event       String
  description String?
  category    String        @default("GENERAL")
  performedBy String?
  createdAt   DateTime      @default(now())

  @@index([expertId])
}

model StudentTimeline {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event       String
  description String?
  category    String         @default("GENERAL")
  performedBy String?
  createdAt   DateTime       @default(now())

  @@index([studentId])
}

// ─────────────────────────────────────────────
// ENUMS & MODELS FOR ENTERPRISE PROJECT MANAGEMENT (ADM-007)
// ─────────────────────────────────────────────

enum ProjectDocumentType {
  PROPOSAL
  SRS
  DESIGN
  CONTRACT
  NDA
  MOU
  REPORT
  DELIVERABLE
  SOURCE_CODE
  OTHER
}

model ProjectMilestone {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, OVERDUE
  dueDate       DateTime?
  completionPct Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
}

model ProjectSprint {
  id          String        @id @default(uuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String        @default("PLANNING") // PLANNING, ACTIVE, COMPLETED
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       ProjectTask[]

  @@index([projectId])
}

model ProjectTask {
  id             String         @id @default(uuid())
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId       String?
  sprint         ProjectSprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  status         String         @default("TODO") // TODO, IN_PROGRESS, IN_REVIEW, DONE, BLOCKED
  priority       String         @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  dueDate        DateTime?
  startDate      DateTime?
  estimatedHours Float          @default(0.0)
  loggedHours    Float          @default(0.0)
  assigneeId     String? // User ID of assignee
  labels         String[]
  dependencies   String[] // Task IDs that this task depends on
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([projectId])
  @@index([sprintId])
}

model ProjectDocument {
  id          String              @id @default(uuid())
  projectId   String
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  docType     ProjectDocumentType @default(OTHER)
  fileUrl     String
  fileSize    Int?
  version     Int                 @default(1)
  status      String              @default("PENDING") // PENDING, APPROVED, REJECTED
  uploadedBy  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([projectId])
}

model ProjectRisk {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  impact      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  probability String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  mitigation  String?
  status      String   @default("ACTIVE") // ACTIVE, MITIGATED, RETIRED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

